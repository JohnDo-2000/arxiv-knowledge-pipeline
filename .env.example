# Copy this file to .env and fill in your own values.
# AWS credentials are picked up via the standard AWS CLI/boto3 credential
# chain (aws configure, environment variables, or an IAM role) -- they
# don't need to go in this file.

# S3 bucket used as the raw landing zone for ingested PDFs
S3_BUCKET=your-arxiv-pipeline-bucket

# Qdrant connection (local Docker default shown)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=arxiv_papers
